<?xml version="1.0" encoding="UTF-8"?>

<openbox_menu xmlns="http://openbox.org/3.4/menu">


<menu id="root-menu" label="Openbox 3">
  <separator label="Applications" />
  <item label="Emacs">
    <action name="Execute">
      <command>emacs</command>
      <startupnotify>
        <enabled>yes</enabled>
        <wmclass>Emacs</wmclass>
      </startupnotify>
    </action>
  </item>

  <item label="Firefox">
    <action name="Execute">
      <command>firefox</command>
      <startupnotify>
        <enabled>yes</enabled>
        <wmclass>Firefox</wmclass>
      </startupnotify>
    </action>
  </item>

  <item label="mpv">
    <action name="Execute">
      <command>mpv</command>
      <startupnotify>
        <enabled>yes</enabled>
      </startupnotify>
    </action>
  </item>

  <item label="Xterm">
    <action name="Execute"><command>xterm</command></action>
  </item>

  <separator label="System" />
  <item label="Manage Cups Printers">
    <action name="Execute">
      <command>xdg-open http://localhost:631/</command>
      <startupnotify>
        <enabled>no</enabled>
        <icon>cups</icon>
      </startupnotify>
    </action>
  </item>
  <item label="Rotate Wallpaper">
    <action name="Execute">
      <command>rotate-wallpaper --once</command>
    </action>
  </item>
  <item label="Reconfigure Openbox">
    <action name="Reconfigure" />
  </item>

  <separator />
  <item label="Lock">
    <action name="Execute">
      <command>lock-screen</command>
    </action>
  </item>
  <item label="Suspend">
    <action name="Execute">
      <command>lock-suspend</command>
    </action>
  </item>
  <item label="Log Out">
    <action name="Exit">
      <prompt>yes</prompt>
    </action>
  </item>
  <item label="Reboot">
    <action name="Execute">
      <command>sudo reboot</command>
    </action>
  </item>
  <item label="Shutdown">
    <action name="Execute">
      <command>sudo poweroff</command>
    </action>
  </item>

</menu>

</openbox_menu>
